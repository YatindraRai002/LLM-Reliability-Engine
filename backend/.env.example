# Backend API Configuration
# Groq API Key for remote model cross-checking
GROQ_API_KEY=your_groq_api_key_here

# Optional: Allowed origins for the FastAPI backend CORS middleware
# Defaults to localhost:3000 if not set
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend Configuration
# URL of the FastAPI backend for the Next.js frontend to call
# Defaults to http://localhost:8000 if not set
NEXT_PUBLIC_API_URL=http://localhost:8000
